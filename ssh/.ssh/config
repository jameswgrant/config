# Keep this file free of secrets.
# Put sensitive identity paths and host-specific credentials in:
#   ~/.ssh/config.local
# and include it from here if needed.

Host *
	ServerAliveInterval 60
	ServerAliveCountMax 3
	IdentitiesOnly yes
	ForwardAgent no

# Example (safe template only):
# Host github.com
#   User git
#   IdentityFile ~/.ssh/id_ed25519
