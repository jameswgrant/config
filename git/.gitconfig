[include]
	path = ~/.gitconfig.local

[init]
	defaultBranch = main

[pull]
	rebase = false

[core]
	editor = vim

[alias]
	co = checkout
	st = status -sb
	pl = pull
	ps = push
	br = branch
	sw = switch
	cm = commit -m
	cma = commit -am
	aa = add -A
	df = diff
	dc = diff --cached
	unstage = restore --staged --
	last = log -1 --stat
	lg = log --graph --date=short --pretty=format:'%C(auto)%h %C(cyan)%ad%Creset %C(green)%an%Creset %C(auto)%d%Creset %s' --all
