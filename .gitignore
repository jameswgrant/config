# OS/editor temp files
.DS_Store
Thumbs.db
*~
*.swp
*.swo
*.tmp
*.bak

# Logs and caches
*.log
**/.cache/
**/.local/state/

# Shell and REPL history
**/.zsh_history
**/.bash_history
**/.lesshst
**/.python_history
**/.node_repl_history

# Environment/local overrides
**/.env
**/.env.*
!**/.env.example
!**/.env.template
**/*.local
**/*.override
!bin/.local/
!bin/.local/**

# Common secret/key material
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.kdbx
**/*.agekey
**/id_rsa
**/id_rsa.pub
**/id_ed25519
**/id_ed25519.pub

# Sensitive config stores
**/.gnupg/
**/.aws/
**/.azure/
**/.config/gcloud/
**/.kube/config

# Ignore private SSH files by default but keep the safe template in this repo
ssh/.ssh/*
!ssh/.ssh/config
